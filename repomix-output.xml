                        </div>
                        <div className='text-center'>Bạn cần hỗ trợ? <span className='text-amber-700'><Link className='hover:underline'>Liên hệ chúng tôi.</Link></span></div>
                    </div>
                </div>
            </div>
        </div>
    );
}
